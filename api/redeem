export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
  if (req.method === 'OPTIONS') return res.status(200).end();

  const SUPABASE_URL = process.env.SUPABASE_URL;
  const SUPABASE_ANON_KEY = process.env.SUPABASE_ANON_KEY;
  const SUPABASE_SERVICE_KEY = process.env.SUPABASE_SERVICE_KEY;
  const token = req.headers.authorization?.replace('Bearer ', '');
  if (!token) return res.status(401).json({ error: 'Unauthorized' });

  const { key, user_id } = req.body;

  // Check key exists and unused
  const kr = await fetch(`${SUPABASE_URL}/rest/v1/gift_keys?key=eq.${key}&used=eq.false`, {
    headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${token}` }
  });
  const keys = await kr.json();
  if (!keys.length) return res.status(400).json({ error: 'Invalid or already used key' });

  const giftKey = keys[0];

  // Mark key as used
  await fetch(`${SUPABASE_URL}/rest/v1/gift_keys?id=eq.${giftKey.id}`, {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'apikey': SUPABASE_SERVICE_KEY || SUPABASE_ANON_KEY,
      'Authorization': `Bearer ${SUPABASE_SERVICE_KEY || token}`
    },
    body: JSON.stringify({ used: true, used_by: user_id })
  });

  // Update user plan
  await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${user_id}`, {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'apikey': SUPABASE_ANON_KEY,
      'Authorization': `Bearer ${token}`
    },
    body: JSON.stringify({ plan: giftKey.plan })
  });

  return res.status(200).json({ success: true, plan: giftKey.plan });
}
